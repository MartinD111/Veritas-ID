# Kopiraj to datoteko v .env in nastavi vrednosti

# Skrivni admin žeton – zamenjaj z dolgim naključnim nizom!
ADMIN_TOKEN=change-me-in-production

# Poti do modelov (relativno ali absolutno)
LLM_MODEL_PATH=models/gemma-4-26b-a4b-it-Q4_K_M.gguf
MMPROJ_MODEL_PATH=models/mmproj-model-f16.gguf

# Kontekstno okno modela (tokeni)
LLM_CONTEXT_SIZE=4096

# Število plasti na GPU (0 = samo CPU)
LLM_GPU_LAYERS=0

# Redis URL
REDIS_URL=redis://localhost:6379/0

# Časovna omejitev Celery nalog (sekunde)
TASK_TIME_LIMIT_SECONDS=300
